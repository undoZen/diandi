<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- 紧凑控制条：状态一行 + 权限/保活按钮一行（授权齐了可视情况隐藏） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="#1c2128">

        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#e8eaed"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/perm_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/btn_notif_access"
                style="@android:style/Widget.Material.Button.Borderless.Small"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#8fd3ff"
                android:text="通知使用权" />

            <Button
                android:id="@+id/btn_battery"
                style="@android:style/Widget.Material.Button.Borderless.Small"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#8fd3ff"
                android:text="电池优化" />

            <Button
                android:id="@+id/btn_autostart"
                style="@android:style/Widget.Material.Button.Borderless.Small"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#8fd3ff"
                android:text="自启动" />

            <Button
                android:id="@+id/btn_ble_perms"
                style="@android:style/Widget.Material.Button.Borderless.Small"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#8fd3ff"
                android:text="BLE 权限" />

            <Button
                android:id="@+id/btn_notifications"
                style="@android:style/Widget.Material.Button.Borderless.Small"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#f0b429"
                android:text="通知" />

            <Button
                android:id="@+id/btn_refresh"
                style="@android:style/Widget.Material.Button.Borderless.Small"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#8fd3ff"
                android:text="刷新" />
        </LinearLayout>
    </LinearLayout>

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
