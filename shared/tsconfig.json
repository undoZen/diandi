{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@diandi/shared": ["./src/index.ts"],
      "@diandi/shared/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
